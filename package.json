{
  "name": "spintax-js",
  "version": "0.0.0",
  "private": true,
  "description": "Spintax engine for JavaScript/TypeScript — monorepo root (@spintax/core + reference consumers)",
  "license": "MIT",
  "author": "301st (https://301.st)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build -w @spintax/core && npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "check:pkg": "npm run check:pkg -w @spintax/core",
    "smoke:pack": "bash scripts/smoke-tarball.sh",
    "bench:postprocess": "node scripts/bench-postprocess.mjs",
    "conformance:validate": "npm run validate -w @spintax/conformance"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "publint": "^0.3.21",
    "typescript-eslint": "^8.63.0"
  }
}
