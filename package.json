{
  "name": "spintax-js",
  "version": "0.0.0",
  "private": true,
  "description": "Spintax engine for JavaScript/TypeScript — monorepo root (pre-code scaffolding)",
  "license": "MIT",
  "author": "301st (https://301.st)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "conformance:validate": "npm run validate -w @spintax/conformance"
  }
}
