  {
    "id": "conditional/case-insensitive-name",
    "note": "Conditional name lookup is case-insensitive (like %var%).",
    "kind": "deterministic",
    "op": "render",
    "template": "{?FLAG?yes|no}",
    "context": {
      "flag": "1"
    },
    "postProcess": false,
    "expect": {
      "output": "yes"
    }
  },
  {
    "id": "variable/recursive-expansion",
    "note": "A context value containing %b% expands recursively (up to MAX_VARIABLE_DEPTH).",
    "kind": "deterministic",
    "op": "render",
    "template": "Hello %a%",
    "context": {
      "a": "%b%",
      "b": "World"
    },
    "postProcess": false,
    "expect": {
      "output": "Hello World"
    }
  },
  {
    "id": "variable/undefined-stays-literal",
    "note": "An unresolved %var% is left verbatim at render time (a warning at validate time, not an error).",
    "kind": "deterministic",
    "op": "render",
    "template": "Hi %missing%",
    "postProcess": false,
    "expect": {
      "output": "Hi %missing%"
    }
  },
  {
    "id": "set/global-scope-inside-group",
    "note": "A #set on its OWN line INSIDE an enumeration is extracted GLOBALLY (like extract_set_directives), so %x% in the other option sees it. rng:last picks the %x% option ⇒ 'A'. Regression for the directive-global-pass gap.",
    "kind": "deterministic",
    "op": "render",
    "template": "{\n#set %x% = A\n|%x%}",
    "rng": "last",
    "postProcess": false,
    "expect": {
      "output": "A"
    }
  }
]
