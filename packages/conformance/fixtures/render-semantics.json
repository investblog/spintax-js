  {
    "id": "conditional/set-truthy",
    "kind": "deterministic",
    "op": "render",
    "template": "{?flag?yes|no}",
    "context": {
      "flag": "1"
    },
    "postProcess": false,
    "expect": {
      "output": "yes"
    }
  },
  {
    "id": "conditional/unset-falsy",
    "kind": "deterministic",
    "op": "render",
    "template": "{?flag?yes|no}",
    "postProcess": false,
    "expect": {
      "output": "no"
    }
  },
  {
    "id": "conditional/whitespace-only-falsy",
    "note": "Truthy = set AND has a non-whitespace char; '   ' is falsy.",
    "kind": "deterministic",
    "op": "render",
    "template": "{?flag?yes|no}",
    "context": {
      "flag": "   "
    },
    "postProcess": false,
    "expect": {
      "output": "no"
    }
  },
  {
    "id": "conditional/zero-is-truthy",
    "note": "'0' is a non-whitespace char ⇒ TRUTHY (a classic gotcha).",
    "kind": "deterministic",
    "op": "render",
    "template": "{?flag?yes|no}",
    "context": {
      "flag": "0"
    },
    "postProcess": false,
    "expect": {
      "output": "yes"
    }
  },
  {
    "id": "conditional/inverted-unset",
