  {
    "id": "plural/ru-one-1",
    "note": "ru: mod10=1, mod100≠11 ⇒ one. Forms are one|few|many.",
    "kind": "deterministic",
    "op": "render",
    "template": "{plural 1: товар|товара|товаров}",
    "locale": "ru",
    "postProcess": false,
    "expect": {
      "output": "товар"
    }
  },
