  {
    "id": "plural/en-one-1",
    "note": "Explicit EN locale (2-form). n=1 ⇒ one. (Omitted-locale defaulting to EN is a TS-only contract, unit-tested, not cross-engine corpus.)",
    "kind": "deterministic",
    "op": "render",
    "template": "{plural 1: item|items}",
    "postProcess": false,
    "expect": {
      "output": "item"
    },
    "locale": "en"
  },
  {
    "id": "plural/en-many-2",
    "kind": "deterministic",
    "op": "render",
    "template": "{plural 2: item|items}",
    "postProcess": false,
    "expect": {
      "output": "items"
    },
    "locale": "en"
  },
  {
    "id": "plural/en-many-0",
    "note": "EN-style: only n=1 is 'one'; 0 ⇒ many.",
