[
  {
    "id": "validate/enumeration-valid",
    "note": "Balanced enumeration.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{a|b|c}",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/nested-enumeration-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "{a|{b|c}}",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/permutation-config-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "[<minsize=2;maxsize=3;sep=\", \";lastsep=\" and \"> a|b|c]",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/set-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %greeting% = hello\n%greeting% world",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/plural-no-locale-structural-only-valid",
    "note": "Arity is skipped without a locale, so a 2-form plural is valid on structural grounds alone.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: one|many}",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/undefined-variable-is-warning-not-error",
    "note": "Parity gate: an unresolved %var% is a WARNING, so the template stays VALID (valid ⇔ no severity:error).",
    "kind": "deterministic",
    "op": "validate",
    "template": "Hello %runtime_name%!",
    "expect": {
      "verdict": "valid",
      "diagnostics": [
        {
          "code": "variable.undefined",
          "severity": "warning"
        }
      ]
    }
  },
  {
    "id": "validate/include-target-not-checked-without-sluglist",
    "note": "With no knownIncludes supplied, include targets are NOT verdict-checked (parity with the plugin).",
    "kind": "deterministic",
    "op": "validate",
    "template": "#include \"anything\"",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/circular-include-is-not-a-static-verdict",
    "note": "A self-referencing #include is a render-time maxDepth guard, NOT a validate() error. Target exists ⇒ valid.",
    "kind": "deterministic",
    "op": "validate",
    "template": "#include \"loop\"",
    "knownIncludes": [
      "loop"
    ],
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/bracket-unclosed",
    "kind": "deterministic",
    "op": "validate",
    "template": "{a|b",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "bracket.unclosed",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/bracket-unexpected-closing",
    "kind": "deterministic",
    "op": "validate",
    "template": "a}",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "bracket.unexpected-closing",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/bracket-mismatched",
    "note": "'{' closed by ']'.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{a|b]",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "bracket.mismatched",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/set-malformed",
    "note": "Missing '=' in #set.",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %v% hello",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "set.malformed",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/permutation-unknown-key",
    "kind": "deterministic",
    "op": "validate",
    "template": "[<foo=1> a|b]",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "permutation.unknown-key",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/permutation-minsize-not-integer",
    "kind": "deterministic",
    "op": "validate",
    "template": "[<minsize=x> a|b]",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "permutation.minsize-not-integer",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/permutation-maxsize-not-integer",
    "kind": "deterministic",
    "op": "validate",
    "template": "[<maxsize=y> a|b]",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "permutation.maxsize-not-integer",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/plural-nested-brackets",
    "note": "Forms slot must not contain nested spintax brackets.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: {a|b}|many}",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.nested-brackets",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/plural-arity-ru-invalid",
    "note": "2-form plural is an arity error for ru (3-form). Locale-sensitive verdict.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: one|many}",
    "locale": "ru",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.arity",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/plural-arity-sr-invalid",
    "note": "Same verdict for sr — BCS is 3-form, so a 2-form template is an arity error.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: one|many}",
    "locale": "sr",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.arity",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/plural-arity-sr-latn-invalid",
    "note": "Arity follows the base language, so a script subtag does not rescue a 2-form template.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: one|many}",
    "locale": "sr-Latn",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.arity",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/plural-arity-sr-valid",
    "note": "Three forms satisfy sr arity.",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: sat|sata|sati}",
    "locale": "sr",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/plural-arity-hr-invalid",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: one|many}",
    "locale": "hr",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.arity",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/plural-arity-bs-invalid",
    "kind": "deterministic",
    "op": "validate",
    "template": "{plural 2: one|many}",
    "locale": "bs",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.arity",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/variable-self-reference",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %a% = x %a% y",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "variable.self-reference",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/variable-circular-reference",
    "note": "A→B→A cycle among #set definitions.",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %a% = %b%\n#set %b% = %a%",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "variable.circular-reference",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/unknown-include-target-invalid",
    "note": "Unknown #include target is a verdict ONLY when knownIncludes is supplied.",
    "kind": "deterministic",
    "op": "validate",
    "template": "#include \"missing-slug\"",
    "knownIncludes": [
      "hero",
      "footer"
    ],
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "include.unknown-target",
          "severity": "error"
        }
      ]
    }
  },
  {
    "id": "validate/def-malformed",
    "kind": "deterministic",
    "op": "validate",
    "template": "#def %v% hello",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "def.malformed"
        }
      ]
    }
  },
  {
    "id": "validate/set-empty-value-is-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %x% =\n%x%",
    "note": "An empty value is legal and the parser accepts it. The validator used to disagree and call it malformed unless a trailing space happened to be present.",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/def-empty-value-is-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "#def %y% =\n%y%",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/definition-duplicate-name",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %x% = a\n#def %x% = b",
    "note": "A name belongs to one directive, once. The set/def maps flatten a collision to last-wins before anyone can see it, which is why occurrences are tracked. Two #set lines sharing a name are the same error.",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "definition.duplicate-name"
        }
      ]
    }
  },
  {
    "id": "validate/definition-duplicate-name-same-kind",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %x% = a\n#set %x% = b",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "definition.duplicate-name"
        }
      ]
    }
  },
  {
    "id": "validate/include-in-def-value",
    "kind": "deterministic",
    "op": "validate",
    "template": "#def %x% = #include \"y\"\n%x%",
    "note": "Includes resolve after a definition is frozen, so one cannot be rolled into a value.",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "def.include-in-value"
        }
      ]
    }
  },
  {
    "id": "validate/include-in-set-value-is-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %x% = #include \"y\"\n%x%",
    "note": "A macro is substituted verbatim, so its #include reaches the include stage in the body, where it works.",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/plural-count-macro",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %n% = {1|4|9}\n{plural %n%: item|items}",
    "note": "The count is still unresolved spintax when the plural is decided, so the block renders empty. #def is the fix.",
    "locale": "en",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.count-macro"
        }
      ]
    }
  },
  {
    "id": "validate/plural-count-macro-permutation",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %n% = [1|2]\n{plural %n%: item|items}",
    "locale": "en",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.count-macro"
        }
      ]
    }
  },
  {
    "id": "validate/plural-count-macro-chained",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %m% = {1|4|9}\n#set %n% = %m%\n{plural %n%: item|items}",
    "note": "%n% carries no bracket at all: taint propagates through #set references to a fixpoint.",
    "locale": "en",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.count-macro"
        }
      ]
    }
  },
  {
    "id": "validate/plural-count-macro-nested-plural",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %n% = {plural 1:1|2}\n{plural %n%: item|items}",
    "note": "A nested plural resolves in the SAME pass as the outer block, not before it, so the outer count is still spintax when read. Exempting it alongside conditionals was a regression.",
    "locale": "en",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.count-macro"
        }
      ]
    }
  },
  {
    "id": "validate/plural-count-macro-enum-inside-conditional",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %flag% = 1\n#set %n% = {?flag?{1|4}|2}\n{plural %n%: item|items}",
    "note": "The conditional resolves in time; the enumeration it uncovers does not.",
    "locale": "en",
    "expect": {
      "verdict": "invalid",
      "diagnostics": [
        {
          "code": "plural.count-macro"
        }
      ]
    }
  },
  {
    "id": "validate/plural-count-conditional-is-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %flag% = 1\n#set %n% = {?flag?1|2}\n{plural %n%: item|items}",
    "note": "Conditionals resolve BEFORE plurals, so this count IS a literal when it is read. This template renders correctly and must not be flagged.",
    "locale": "en",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/plural-count-def-is-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "#def %n% = {1|4|9}\n{plural %n%: item|items}",
    "note": "A #def is frozen to literal text before the walk begins, which is what makes it the fix the diagnostic points at.",
    "locale": "en",
    "expect": {
      "verdict": "valid"
    }
  },
  {
    "id": "validate/plural-count-literal-set-is-valid",
    "kind": "deterministic",
    "op": "validate",
    "template": "#set %n% = 5\n{plural %n%: item|items}",
    "locale": "en",
    "expect": {
      "verdict": "valid"
    }
  }
]
