[
  {
    "id": "postprocess/capitalize-first-letter",
    "kind": "deterministic",
    "op": "render",
    "template": "hello world",
    "postProcess": true,
    "expect": {
      "output": "Hello world"
    }
  },
  {
    "id": "postprocess/capitalize-after-period",
    "kind": "deterministic",
    "op": "render",
    "template": "hello. world",
    "postProcess": true,
    "expect": {
      "output": "Hello. World"
    }
  },
  {
    "id": "postprocess/capitalize-after-ellipsis",
    "note": "The ellipsis char … (U+2026) is a sentence terminator for capitalization.",
    "kind": "deterministic",
    "op": "render",
    "template": "wait… really",
    "postProcess": true,
    "expect": {
      "output": "Wait… Really"
    }
  },
  {
    "id": "postprocess/capitalize-after-linebreak",
    "kind": "deterministic",
    "op": "render",
    "template": "line one\nline two",
    "postProcess": true,
    "expect": {
      "output": "Line one\nLine two"
    }
  },
  {
    "id": "postprocess/collapse-multiple-spaces",
    "note": "Leading uppercase avoids first-letter-cap noise; isolates the space-collapse rule.",
    "kind": "deterministic",
    "op": "render",
    "template": "Word  with   spaces",
    "postProcess": true,
    "expect": {
      "output": "Word with spaces"
    }
  },
  {
    "id": "postprocess/remove-space-before-comma",
    "kind": "deterministic",
    "op": "render",
    "template": "Word , next",
    "postProcess": true,
    "expect": {
      "output": "Word, next"
    }
  },
  {
    "id": "postprocess/remove-space-before-exclamation",
    "kind": "deterministic",
    "op": "render",
    "template": "Hello ! World",
    "postProcess": true,
    "expect": {
      "output": "Hello! World"
    }
  },
  {
    "id": "postprocess/add-space-after-comma",
    "kind": "deterministic",
    "op": "render",
    "template": "one,two",
    "postProcess": true,
    "expect": {
      "output": "One, two"
    }
  },
  {
    "id": "postprocess/digit-after-comma-not-spaced",
    "note": "The (?!\\d) lookahead protects number groups like 3,14 from getting a space.",
    "kind": "deterministic",
    "op": "render",
    "template": "Price 3,14 eur",
    "postProcess": true,
    "expect": {
      "output": "Price 3,14 eur"
    }
  },
  {
    "id": "postprocess/period-then-letter-spaced-and-capped",
    "kind": "deterministic",
    "op": "render",
    "template": "a.b",
    "postProcess": true,
    "expect": {
      "output": "A. B"
    }
  },
  {
    "id": "postprocess/decimal-shielded",
    "note": "Decimal 2.5 is shielded so its dot is not a sentence boundary.",
    "kind": "deterministic",
    "op": "render",
    "template": "Version 2.5 released",
    "postProcess": true,
    "expect": {
      "output": "Version 2.5 released"
    }
  },
  {
    "id": "postprocess/url-shielded",
    "note": "A full URL survives post-process intact (no punctuation/cap mangling inside).",
    "kind": "deterministic",
    "op": "render",
    "template": "visit https://example.com now",
    "postProcess": true,
    "expect": {
      "output": "Visit https://example.com now"
    }
  },
  {
    "id": "postprocess/url-trailing-punctuation",
    "note": "A trailing '.' is split off the URL so it still ends the sentence, URL stays intact.",
    "kind": "deterministic",
    "op": "render",
    "template": "see https://example.com.",
    "postProcess": true,
    "expect": {
      "output": "See https://example.com."
    }
  },
  {
    "id": "postprocess/email-shielded",
    "kind": "deterministic",
    "op": "render",
    "template": "mail me@example.com please",
    "postProcess": true,
    "expect": {
      "output": "Mail me@example.com please"
    }
  },
  {
    "id": "postprocess/mailto-uri-shielded",
    "note": "mailto: has no // authority so the URL rule misses it; it must be shielded before the EMAIL pass so the whole href survives instead of a bare 'mailto:' getting a space injected after its colon (spintax-js#41).",
    "kind": "deterministic",
    "op": "render",
    "template": "email mailto:contact@example.com now",
    "postProcess": true,
    "expect": {
      "output": "Email mailto:contact@example.com now"
    }
  },
  {
    "id": "postprocess/mailto-uri-in-href-shielded",
    "note": "The production bug: the email shield carved contact@example.com out of the href, leaving 'mailto:' whose colon then got a space, producing a malformed 'mailto: contact@…' link.",
    "kind": "deterministic",
    "op": "render",
    "template": "<a href=\"mailto:contact@example.com\">write us</a>",
    "postProcess": true,
    "expect": {
      "output": "<a href=\"mailto:contact@example.com\">Write us</a>"
    }
  },
  {
    "id": "postprocess/mailto-uri-trailing-punctuation",
    "note": "A trailing '.' is split off the mailto: URI (like URLs) so it still ends the sentence and caps the next word, address intact.",
    "kind": "deterministic",
    "op": "render",
    "template": "see mailto:contact@example.com. next",
    "postProcess": true,
    "expect": {
      "output": "See mailto:contact@example.com. Next"
    }
  },
  {
    "id": "postprocess/tel-uri-shielded",
    "note": "tel: URI shielded before the 'space after colon' rule can split 'tel:' from its number.",
    "kind": "deterministic",
    "op": "render",
    "template": "reach us at tel:+1-800-555-0000 today",
    "postProcess": true,
    "expect": {
      "output": "Reach us at tel:+1-800-555-0000 today"
    }
  },
  {
    "id": "postprocess/bare-domain-shielded-then-sentence",
    "note": "Domain is shielded; the '.' after it still ends the sentence and caps the next word.",
    "kind": "deterministic",
    "op": "render",
    "template": "visit example.com. next",
    "postProcess": true,
    "expect": {
      "output": "Visit example.com. Next"
    }
  },
  {
    "id": "postprocess/punycode-domain-shielded",
    "kind": "deterministic",
    "op": "render",
    "template": "open xn--e1afmapc.xn--p1ai today",
    "postProcess": true,
    "expect": {
      "output": "Open xn--e1afmapc.xn--p1ai today"
    }
  },
  {
    "id": "postprocess/abbrev-whitelist-ru",
    "note": "Single-token abbreviation 'соц.' is whitelisted, so 'сети' is NOT falsely capitalized.",
    "kind": "deterministic",
    "op": "render",
    "template": "Текст соц. сети тут",
    "postProcess": true,
    "expect": {
      "output": "Текст соц. сети тут"
    }
  },
  {
    "id": "postprocess/abbrev-whitelist-en",
    "note": "'Mr.' is whitelisted, so 'smith' is not treated as a new sentence.",
    "kind": "deterministic",
    "op": "render",
    "template": "call Mr. smith now",
    "postProcess": true,
    "expect": {
      "output": "Call Mr. smith now"
    }
  },
  {
    "id": "postprocess/abbrev-multidot",
    "note": "Multi-dot abbreviation 'e.g.' (2+ dotted groups) is shielded by step 5a. NB: step 5a uses \\b, which — like PHP PCRE without UCP — is ASCII, so it shields ASCII abbreviations but NOT a Cyrillic one like т.д. (parity holds; the ru whitelist covers single-token Cyrillic via a \\p{L} lookbehind).",
    "kind": "deterministic",
    "op": "render",
    "template": "See e.g. this",
    "postProcess": true,
    "expect": {
      "output": "See e.g. this"
    }
  },
  {
    "id": "postprocess/trim-and-collapse",
    "note": "Leading/trailing whitespace collapses then trims; first letter capitalizes.",
    "kind": "deterministic",
    "op": "render",
    "template": "  hello  ",
    "postProcess": true,
    "expect": {
      "output": "Hello"
    }
  },
  {
    "id": "postprocess/es-opener-capitalize-start",
    "note": "Spanish opens a question with an inverted mark. The capitalizer upper-cases the first CHARACTER after a sentence boundary; '¿' has no uppercase form, so without an opener rule the real first letter stays lowercase. SENTENCE_OPENERS = '¿¡' only — quotes/brackets are NOT openers (they also close, and capitalizing after them would mangle list markers).",
    "kind": "deterministic",
    "op": "render",
    "template": "¿cómo estás?",
    "postProcess": true,
    "expect": {
      "output": "¿Cómo estás?"
    }
  },
  {
    "id": "postprocess/es-opener-capitalize-after-sentence",
    "note": "Opener sits between the sentence-ending punctuation and the first letter. Covers both inverted marks.",
    "kind": "deterministic",
    "op": "render",
    "template": "hola. ¿cómo estás? ¡genial!",
    "postProcess": true,
    "expect": {
      "output": "Hola. ¿Cómo estás? ¡Genial!"
    }
  },
  {
    "id": "postprocess/es-opener-binds-to-word",
    "note": "An opener binds to the word it opens: '¿ qué' -> '¿qué'. This spacing pass MUST run before capitalization, so the capitalizer sees the real first letter and not a space. The second input ('¿cómo', no space) proves the rule is not merely a whitespace artefact.",
    "kind": "deterministic",
    "op": "render",
    "template": "Hola. ¿ qué tal ? ¡ genial !",
    "postProcess": true,
    "expect": {
      "output": "Hola. ¿Qué tal? ¡Genial!"
    }
  },
  {
    "id": "postprocess/es-opener-after-block-tag",
    "note": "The plugin's primary output is HTML paragraphs, so an opener after a block-level tag is the commonest real case of all.",
    "kind": "deterministic",
    "op": "render",
    "template": "<p>¿cómo estás?</p><p>¡genial!</p>",
    "postProcess": true,
    "expect": {
      "output": "<p>¿Cómo estás?</p><p>¡Genial!</p>"
    }
  },
  {
    "id": "postprocess/es-opener-after-line-break",
    "note": "Multi-line templates hit the newline capitalization rule rather than the sentence-punctuation one.",
    "kind": "deterministic",
    "op": "render",
    "template": "Hola.\n¿cómo estás?",
    "postProcess": true,
    "expect": {
      "output": "Hola.\n¿Cómo estás?"
    }
  },
  {
    "id": "postprocess/opener-set-excludes-quotes-and-brackets",
    "note": "Guards the deliberate NARROWNESS of SENTENCE_OPENERS. A quote or bracket is not an opener: capitalizing after one would break list markers like '(a) primero'. If this case ever starts capitalizing, the contract was widened by accident.",
    "kind": "deterministic",
    "op": "render",
    "template": "Elige una. (a) primero",
    "postProcess": true,
    "expect": {
      "output": "Elige una. (a) primero"
    }
  }
]
