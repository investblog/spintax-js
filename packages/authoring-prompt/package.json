{
  "name": "@spintax/authoring-prompt",
  "version": "0.0.0",
  "private": true,
  "description": "Canonical LLM prompt for authoring spintax templates — one prompt, shared by the bot, the n8n node, the playground and the API (DRAFT, not published)",
  "license": "MIT",
  "author": "301st (https://301.st)",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@spintax/core": ">=0.1.3"
  },
  "devDependencies": {
    "@spintax/core": "*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
