{
  "name": "@spintax/core",
  "version": "0.1.5",
  "description": "Framework-agnostic spintax / text-spinning engine for JS & TS — turn one LLM-drafted {a|b|c} template into endless deterministic variations. Render, validate, extract. Zero-dependency; Node, Workers, browser.",
  "keywords": [
    "spintax",
    "text-spinning",
    "text-spinner",
    "text-generation",
    "content-generation",
    "template",
    "template-engine",
    "email-template",
    "placeholders",
    "variables",
    "conditionals",
    "seo",
    "permutations",
    "substitution",
    "variations",
    "ai",
    "llm",
    "typescript"
  ],
  "license": "MIT",
  "author": "301st (https://301.st)",
  "homepage": "https://spintax.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/investblog/spintax-js.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/investblog/spintax-js/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "check:pkg": "publint --strict && attw --pack .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
