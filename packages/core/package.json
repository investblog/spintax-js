{
  "name": "@spintax/core",
  "version": "0.0.0",
  "description": "GTW-compatible spintax parser, renderer, validator and variable extractor — framework-agnostic",
  "keywords": [
    "spintax",
    "gtw",
    "template",
    "text generation",
    "seo",
    "content"
  ],
  "license": "MIT",
  "author": "301st (https://301.st)",
  "homepage": "https://spintax.net",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
